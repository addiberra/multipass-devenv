# Example secrets file for secure dev environment
# Copy this file to secrets.env and fill in your values
# NEVER commit secrets.env to version control

# Required: OpenAI API key for LLM access
OPENAI_API_KEY=sk-your-openai-api-key-here

# Required: Git user name for commits
GIT_USER_NAME=Your Name

# Required: Git user email for commits
GIT_USER_EMAIL=your@email.com

# Optional: OpenCode API key (if using OpenCode provider)
# OPENCODE_API_KEY=your-opencode-api-key-here

# Optional: Additional environment variables
# Add any other keys you need for your workflow
# They will be written to /home/opencode/.config/opencode/secrets.env