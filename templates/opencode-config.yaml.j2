{#
  OpenCode configuration template
  Injected with secrets via cloud-init write_files directive
  
  Variables:
    - OPENAI_API_KEY: API key for OpenAI
    - OPENCODE_API_KEY: Optional API key for OpenCode provider
    - GIT_USER_NAME: Git user name for commits
    - GIT_USER_EMAIL: Git user email for commits
#}

# OpenCode CLI configuration
# Generated by launch.sh from secrets.env

api_key: "{{ OPENAI_API_KEY }}"

{% if OPENCODE_API_KEY is defined and OPENCODE_API_KEY %}
opencode_api_key: "{{ OPENCODE_API_KEY }}"
{% endif %}

# Model configuration
model: "{{ model | default('gpt-4') }}"

# Git configuration (written to ~/.gitconfig separately)
# These values are used by OpenCode for commits
git_config:
  user_name: "{{ GIT_USER_NAME }}"
  user_email: "{{ GIT_USER_EMAIL }}"